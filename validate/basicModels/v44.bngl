begin model
begin parameters
  kf 0.1
end parameters
begin compartments
  EC  3  1000
  PM  2  10    EC
  CP  3  1     PM
end compartments
begin molecule types
  L(r)
  R(l)
end molecule types
begin seed species
  @EC:$L(r)  50
  @PM:R(l)   20
end seed species
begin observables
  Molecules Lfree  L(r)
  Molecules Rtot   R()
end observables
begin reaction rules
  @EC:L(r) + @PM:R(l) -> @PM:L(r!1).R(l!1) kf
end reaction rules
generate_network({overwrite=>1})
simulate_ode({suffix=>"ode",t_end=>10,n_steps=>10})
resetConcentrations()
simulate_ssa({suffix=>"ssa",t_end=>10,n_steps=>10})
resetConcentrations()
writeXML()
end model
